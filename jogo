using UnityEngine;

/// <summary>
/// Controlador principal do jogo de Pega-Pega Cartoon.
/// Resolve os problemas de movimentação pesada, física rígida e velocidades estáticas.
/// </summary>
[RequireComponent(typeof(CharacterController))]
public class ControladorPegaPega : MonoBehaviour
{
    [Header("--- CONFIGURAÇÕES DE MOVIMENTO ---")]
    [Tooltip("Velocidade do jogador quando ele está fugindo.")]    
    public float velocidadeFugitivo = 8f;
    
    [Tooltip("Velocidade do jogador quando ele é o caçador (mais rápido para equilíbrio).")]
    public float velocidadePegador = 9.5f; 
    
    private float velocidadeAtual;
    public float velocidadeRotacao = 15f;

    [Header("--- FÍSICA CARTOON (GAME FEEL) ---")]
    public float forcaPulo = 12f;
    public float gravidadeCartoon = 30f;
    public float multiplicadorQuedaRapida = 1.5f;

    [Header("--- MECÂNICA DE SLIDE ---")]
    public float velocidadeSlide = 16f;
    public float duracaoSlide = 0.6f;
    private float tempoSlideRestante;
    private bool estaDeslizando;

    [Header("--- ESTADO DO JOGADOR ---")]
    public bool ehOPegador = false;

    private CharacterController controller;
    private Vector3 direcaoMovimento;
    private Vector3 velocidadeVertical;

    void Start()
    {
        controller = GetComponent<CharacterController>();
        velocidadeAtual = ehOPegador ? velocidadePegador : velocidadeFugitivo;
    }

    void Update()
    {
        ProcessarMovimento();
        ProcessarPuloEGravidade();
        ProcessarSlide();

        // Aplicação final do vetor de movimento na Unity
        Vector3 movimentoFinal = (direcaoMovimento * velocidadeAtual) + velocidadeVertical;
        controller.Move(movimentoFinal * Time.deltaTime);
    }

    private void ProcessarMovimento()
    {
        if (estaDeslizando) return; 

        float moverX = Input.GetAxisRaw("Horizontal");
        float moverZ = Input.GetAxisRaw("Vertical");

        direcaoMovimento = new Vector3(moverX, 0, moverZ).normalized;

        if (direcaoMovimento != Vector3.zero)
        {
            Quaternion rotacaoAlvo = Quaternion.LookRotation(direcaoMovimento);
            transform.rotation = Quaternion.Slerp(transform.rotation, rotacaoAlvo, velocidadeRotacao * Time.deltaTime);
            velocidadeAtual = ehOPegador ? velocidadePegador : velocidadeFugitivo;
        }
        else
        {
            velocidadeAtual = 0;
        }
    }

    private void ProcessarPuloEGravidade()
    {
        if (controller.isGrounded && velocidadeVertical.y < 0)
        {
            velocidadeVertical.y = -2f;
        }

        if (Input.GetButtonDown("Jump") && controller.isGrounded && !estaDeslizando)
        {
            velocidadeVertical.y = forcaPulo;
        }

        // Queda mais rápida para gerar efeito cartoon (Peso Dinâmico)
        if (velocidadeVertical.y < -2f)
        {
            velocidadeVertical.y -= gravidadeCartoon * multiplicadorQuedaRapida * Time.deltaTime;
        }
        else
        {
            velocidadeVertical.y -= gravidadeCartoon * Time.deltaTime;
        }
    }

    private void ProcessarSlide()
    {
        if (Input.GetKeyDown(KeyCode.LeftControl) && controller.isGrounded && direcaoMovimento != Vector3.zero && !estaDeslizando)
        {
            estaDeslizando = true;
            tempoSlideRestante = duracaoSlide;
            transform.localScale = new Vector3(1f, 0.5f, 1f); // Efeito visual de achatamento (Squash)
        }

        if (estaDeslizando)
        {
            tempoSlideRestante -= Time.deltaTime;
            velocidadeAtual = velocidadeSlide; 

            if (tempoSlideRestante <= 0)
            {
                estaDeslizando = false;
                transform.localScale = new Vector3(1f, 1f, 1f); // Retorna ao estado normal
            }
        }
    }
}
